{
  "name": "nik-dev-infra",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Always-on dev infrastructure for the Nik app — parallel Claude Code agents watching the codebase, surfacing drift / hardcoded data / wiring issues live.",
  "scripts": {
    "start": "concurrently -n daemon,ui -c blue,magenta \"npm run daemon\" \"npm run ui\"",
    "daemon": "tsx watch src/server/index.ts",
    "ui": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "verify:ws": "node scripts/verify-ws.mjs",
    "screenshots:login": "node scripts/screenshots-login.mjs",
    "screenshots": "node scripts/take-screenshots.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/static": "^8.0.4",
    "@fastify/websocket": "^11.0.2",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^4.0.3",
    "cytoscape": "^3.33.2",
    "cytoscape-fcose": "^2.2.0",
    "execa": "^9.5.2",
    "fastify": "^5.2.1",
    "minimatch": "^10.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "playwright": "^1.59.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
